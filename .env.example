# Environment Variables for HPC Backend
# Copy this file to .env.local for local development
# For Vercel deployment, set these in Project Settings -> Environment Variables

# Comma-separated list of blacklisted user IDs
# Example: BLACKLIST_IDS=12345678,87654321,11111111,22222222
BLACKLIST_IDS=

# Optional: Custom messages (uncomment to use)
# BLACKLISTED_MESSAGE=YOU'RE BLACKLISTED, IDK WHY YOU THOUGHT YOU COULD COME IN HERE
# ACCESS_GRANTED_MESSAGE=Access granted

# Node Environment (usually set automatically by Vercel)
# NODE_ENV=development